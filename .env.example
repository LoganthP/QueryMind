# QueryMind — Environment Configuration
# Copy this file to .env and fill in your values

# OpenRouter API Key (required for AI features)
OPENROUTER_API_KEY="your-openrouter-api-key-here"

# OpenRouter Model Settings
MODEL_ID=anthropic/claude-sonnet-4
APP_REFERER=https://querymind.app
APP_TITLE=QueryMind SQL Assistant

# Default SQLite database path (relative to backend/)
DEFAULT_DB_PATH=./sample.db

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# Write mode: allow INSERT/UPDATE/DELETE queries
WRITE_MODE_ENABLED=false

# Maximum rows returned per query
MAX_ROWS_RETURNED=500

# Rate limiting (requests per minute per session)
RATE_LIMIT_PER_MINUTE=20
